{
    # Lokale CA für .local Domains
    local_certs
    log {
        level INFO
    }
}

{$MEMORY_HOST:memory.local} {

    # ── Security Headers ──────────────────────────────────────────────────
    header {
        X-Frame-Options             "DENY"
        X-Content-Type-Options      "nosniff"
        X-XSS-Protection            "1; mode=block"
        Referrer-Policy             "strict-origin-when-cross-origin"
        Strict-Transport-Security   "max-age=31536000; includeSubDomains"
        Content-Security-Policy     "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'"
        Permissions-Policy          "camera=(), microphone=(), geolocation=()"
        -Server
    }

    # ── MCP-Endpunkt (Streamable HTTP via auth-proxy → memcp) ────────────
    handle /mcp* {
        reverse_proxy auth-proxy:4000 {
            header_up X-Forwarded-For {remote_host}
            header_up X-Real-IP {remote_host}
            flush_interval -1
            transport http {
                read_timeout 300s
                write_timeout 300s
            }
        }
    }

    # ── Admin REST-API ────────────────────────────────────────────────────
    handle /api* {
        basicauth {
            {$ADMIN_USER} {$ADMIN_PASSWORD_HASH}
        }
        reverse_proxy admin-api:3459 {
            header_up X-Admin-Key {$ADMIN_API_KEY}
        }
    }

    # ── Admin Web-Dashboard ───────────────────────────────────────────────
    handle /admin* {
        basicauth {
            {$ADMIN_USER} {$ADMIN_PASSWORD_HASH}
        }
        uri strip_prefix /admin
        reverse_proxy admin-ui:8080
    }

    # ── Health-Check (kein Auth) ──────────────────────────────────────────
    handle /health {
        reverse_proxy auth-proxy:4000
    }

    # ── Root Redirect zu Admin ────────────────────────────────────────────
    handle / {
        redir /admin/ 302
    }

    tls internal
}
