# Server 
MEMORY_HOST=memory.local
MEMORY_PORT=443

# Admin-UI Auth 
ADMIN_USER=admin
# Generieren mit: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'deinPasswort'
ADMIN_PASSWORD_HASH=$2a$14$...

# Interne API-Sicherheit 
# Generieren mit: openssl rand -hex 32
ADMIN_API_KEY=changeme-generate-with-openssl-rand-hex-32
JWT_SECRET=changeme-generate-with-openssl-rand-hex-32

#  Memory-Service 
MAX_RECALL_TOKENS=450
SIMILARITY_THRESHOLD=0.35
MAX_RESULTS_L2=3
MAX_RULES_L3=5

#  Embedding 
OLLAMA_MODEL=nomic-embed-text
OLLAMA_URL=http://ollama:11434

#  Scheduler 
GC_SCHEDULE=0 2 * * *
DISTILL_SCHEDULE=30 2 * * *
BACKUP_SCHEDULE=0 3 * * *
DECAY_SCHEDULE=0 4 * * *
RULE_MIN_EPISODES=3
DECAY_FACTOR=0.002
MAX_DB_SIZE_MB=500

#  Resource Limits 
MEM_LIMIT_SERVICE=512m
MEM_LIMIT_OLLAMA=2g
MEM_LIMIT_ADMIN=256m
CPU_LIMIT_SERVICE=1.0
CPU_LIMIT_OLLAMA=2.0

#  Business-OS Adapter (optional) 
ADAPTER_SOURCE=nextcloud
ADAPTER_API_URL=https://nextcloud.local
ADAPTER_API_KEY=
ADAPTER_SYNC_SCHEDULE=0 */6 * * *
ADAPTER_NAMESPACES=business:projects,business:docs
ADAPTER_FILTER_FIELDS=
ADAPTER_MAX_AGE_DAYS=90
ADAPTER_MEMORY_API_KEY=
